{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vision Goblin",
  "version": "0.1.0",
  "identifier": "com.vision-goblin",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vision Goblin",
        "width": 1440,
        "height": 920,
        "minWidth": 1040,
        "minHeight": 720,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "dialog": null,
    "fs": null,
    "store": null
  }
}
